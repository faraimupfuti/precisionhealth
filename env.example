# ClaraVision Health - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===================================
# EMAIL CONFIGURATION (Optional)
# ===================================
# Required for email report functionality
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SENDER_EMAIL=noreply@claravision.health

# ===================================
# ROBOFLOW API CONFIGURATION
# ===================================
# Your Roboflow API credentials (already hardcoded in app, but good practice to externalize)

# ROBOFLOW_API_KEY=cmnlsaDgw7FTB0sVFZx2
# ROBOFLOW_MODEL_ENDPOINT=https://serverless.roboflow.com/precisionhealth-skin-condition-classification/9

# ===================================
# APPLICATION CONFIGURATION
# ===================================
# Optional configuration for production deployments

# APP_NAME=ClaraVision Health
# APP_VERSION=1.0.0
# ENVIRONMENT=development  # development, staging, production

# ===================================
# DATABASE CONFIGURATION (Future)
# ===================================
# For future user management and analytics features

# DATABASE_URL=postgresql://user:password@localhost:5432/claravision
# REDIS_URL=redis://localhost:6379

# ===================================
# SECURITY CONFIGURATION (Future)
# ===================================
# For authentication and authorization features

# SECRET_KEY=your-secret-key-here
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================================
# MONITORING & ANALYTICS (Future)
# ===================================
# For production monitoring

# SENTRY_DSN=your-sentry-dsn-here
# GOOGLE_ANALYTICS_ID=your-ga-id-here

# ===================================
# NOTES
# ===================================
# 1. Never commit .env file to version control
# 2. Keep .env.example updated when adding new variables
# 3. Use strong, unique passwords for all credentials
# 4. Rotate API keys and passwords regularly
# 5. Use environment-specific values for different deployments
